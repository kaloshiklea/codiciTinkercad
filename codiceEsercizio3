int p = 0;

void setup(){
  pinMode(2, INPUT);
  pinMode(8, OUTPUT);
  pinMode(9, OUTPUT);
  pinMode(10, OUTPUT);
}

void loop(){
  digitalWrite(8, LOW);
  digitalWrite(9,LOW);
  digitalWrite(10,LOW);
  p = digitalRead(2);
}

digitalWrite(8, HIGH);
digitalWrite(9,LOW);
digitalWrite(10,LOW);
delay(3000);

digitalWrite(8, LOW);
digitalWrite(9,HIGH);
digitalWrite(10,LOW);
delay(1000);

digitalWrite(8, LOW);
digitalWrite(9,LOW);
digitalWrite(10,HIGH);
delay(3000);
}
